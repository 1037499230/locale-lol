{
  "name": "el",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "start": "cross-env NODE_ENV=development electron ."
  },
  "dependencies": {
    "element-plus": "^2.14.0",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^42.0.1",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "wait-on": "^8.0.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.el.app",
    "productName": "El App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
